generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model StoreAdministrator {
  storeId    Int        @id @default(autoincrement())
  storeName  String
  user       String     @unique
  password   String
  role       String     @default("STORE_ADMIN")
  categories Category[]
  products   Product[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  storeId   Int
  store     StoreAdministrator @relation(fields: [storeId], references: [storeId], onDelete: Cascade)
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([storeId])
}

model Product {
  id          String    @id @default(cuid())
  code        String
  name        String
  measureUnit String
  stock       Float     @default(0)
  storeId     Int
  store       StoreAdministrator @relation(fields: [storeId], references: [storeId], onDelete: Cascade)
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([storeId])
  @@unique([storeId, code])
}
